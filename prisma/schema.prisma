generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Holding agrupa empresas. O acesso multi-usuário é concedido no nível do Holding.
model Holding {
  id          String       @id @default(cuid())
  name        String
  color       String       @default("#6366f1")
  createdAt   DateTime     @default(now())
  companies   Company[]
  operations  Operation[]
  memberships Membership[]
}

// Operação = unidade operacional (toca sites/custos), cruza empresas. Cada CONTA
// pertence a uma operação → as transações herdam a operação. Acesso pode ser por
// operação (operador vê só a dele).
model Operation {
  id          String                @id @default(cuid())
  name        String
  type        String                @default("own") // "own" (própria) | "holding"
  color       String                @default("#0ea5e9")
  holdingId   String?
  holding     Holding?              @relation(fields: [holdingId], references: [id])
  createdAt      DateTime              @default(now())
  accounts       Account[]
  transactions   Transaction[]
  splits         TransactionSplit[]
  memberships    OperationMembership[]
  credentials    Credential[]
  metaAdAccounts MetaAdAccount[]

  @@index([holdingId])
}

// Acesso de um usuário a UMA operação (vê só as contas/transações daquela operação).
model OperationMembership {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, operationId])
  @@index([userId])
  @@index([operationId])
}

model Company {
  id        String    @id @default(cuid())
  name      String
  cnpj      String?   @unique
  color     String    @default("#6366f1")
  holdingId String?
  holding   Holding?  @relation(fields: [holdingId], references: [id])
  createdAt DateTime  @default(now())
  accounts  Account[]

  @@index([holdingId])
}

model Account {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  bank         String
  currency     String
  name         String
  apiToken     String? // token da API do banco — 1 token por conta (ex.: Mercury)
  syncConfig   String? // JSON: { mercuryAccountId?, mercuryEntity?, wiseProfileId? }
  operationId  String? // operação dona desta conta (as transações herdam)
  operation    Operation?    @relation(fields: [operationId], references: [id])
  createdAt    DateTime      @default(now())
  transactions Transaction[]

  @@index([companyId])
  @@index([operationId])
}

model Category {
  id               String               @id @default(cuid())
  type             String
  name             String
  code             String?
  parentId         String?
  parent           Category?            @relation("CategoryChildren", fields: [parentId], references: [id])
  children         Category[]           @relation("CategoryChildren")
  color            String               @default("#6366f1")
  isInternal       Boolean              @default(false)
  plSection        String?
  createdAt        DateTime             @default(now())
  managerialSplits     TransactionSplit[]   @relation("ManagerialCategory")
  accountingSplits     TransactionSplit[]   @relation("AccountingCategory")
  accountingSplits2    AccountingSplit[]    @relation("AccountingSplitCategory")
  chartLines       DashboardChartLine[]
}

model Transaction {
  id               String             @id @default(cuid())
  accountId        String
  account          Account            @relation(fields: [accountId], references: [id])
  date             DateTime
  description      String
  amount           Float
  currency         String
  reference        String?
  fee              Float?             @default(0)
  ignored          Boolean            @default(false)
  importedAt       DateTime           @default(now())
  // Checagem Meta (anti-vazamento de cartão)
  cardLast4        String? // últimos 4 do cartão usado (extraído no import)
  cardLabel        String? // nome do cartão no banco (ex.: Revolut "BM 14 Snapnork") — só p/ exibição
  isMetaCharge     Boolean            @default(false) // cobrança classificada como Meta/Facebook
  metaRef          String? // código do descritor "Facebk *XXXX" extraído do extrato (= [transação][conta][cartão])
  metaCheck        String? // [legado] resíduo do match antigo — não usado
  metaCheckNote    String? // [legado] resíduo do match antigo — não usado
  // Valor ORIGINAL cobrado (antes do câmbio) — Meta cobra em USD; base da reconciliação gasto×cobrança
  billAmount       Float?
  billCurrency     String?
  operationId      String? // operação da transação (default herdado da conta; editável)
  operation        Operation?         @relation(fields: [operationId], references: [id])
  splits           TransactionSplit[]
  accountingSplits AccountingSplit[]
  documents        Document[]

  @@unique([accountId, reference])
  @@index([accountId])
  @@index([date])
  @@index([isMetaCharge])
  @@index([cardLast4])
  @@index([operationId])
}

model AccountingSplit {
  id                   String      @id @default(cuid())
  transactionId        String
  transaction          Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount               Float
  note                 String?
  accountingDate       DateTime?
  accountingCategoryId String?
  accountingCategory   Category?   @relation("AccountingSplitCategory", fields: [accountingCategoryId], references: [id])
  createdAt            DateTime    @default(now())

  @@index([transactionId])
  @@index([accountingCategoryId])
}

model TransactionSplit {
  id                   String      @id @default(cuid())
  transactionId        String
  transaction          Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  amount               Float
  note                 String?
  accountingDate       DateTime?
  managerialCategoryId String?
  managerialCategory   Category?   @relation("ManagerialCategory", fields: [managerialCategoryId], references: [id])
  accountingCategoryId String?
  accountingCategory   Category?   @relation("AccountingCategory", fields: [accountingCategoryId], references: [id])
  operationId          String? // operação desta linha de split (divide a transação entre operações)
  operation            Operation?  @relation(fields: [operationId], references: [id])
  createdAt            DateTime    @default(now())

  @@index([transactionId])
  @@index([managerialCategoryId])
  @@index([accountingCategoryId])
  @@index([operationId])
  // compostos: aceleram o EXISTS correlacionado (splits.some por categoria) usado nos filtros/contagem da lista
  @@index([managerialCategoryId, transactionId])
  @@index([accountingCategoryId, transactionId])
}

model DashboardChart {
  id        String               @id @default(cuid())
  name      String
  color     String               @default("#00b9a5")
  order     Int                  @default(0)
  lines        DashboardChartLine[]
  seriesLinks  ChartSeriesLink[]
  unit         String  @default("currency")
  format       String  @default("auto")
  createdAt DateTime             @default(now())
}

model DashboardChartLine {
  id         String         @id @default(cuid())
  chartId    String
  chart      DashboardChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id])
  factor     Int            @default(1)
  order      Int            @default(0)
  yAxis      String         @default("left")

  @@index([chartId])
  @@index([categoryId])
}

model PlanSeries {
  id         String           @id @default(cuid())
  name       String
  color      String           @default("#f59e0b")
  seriesType String           @default("line") // "line" | "bar"
  unit       String           @default("currency") // "currency" | "percentage" | "index" | "time" | "count"
  format     String           @default("auto") // "auto" | "thousands" | "millions" | "raw" | "percentage"
  order      Int              @default(0)
  values     PlanSeriesValue[]
  chartLinks ChartSeriesLink[]
  createdAt  DateTime         @default(now())
  // Derived (formula) series
  formulaOp        String?    // "+" | "-" | "*" | "/"
  formulaSeriesAId String?    // PlanSeries id (mutually exclusive with formulaChartAId)
  formulaSeriesBId String?    // PlanSeries id (mutually exclusive with formulaChartBId)
  formulaChartAId  String?    // DashboardChart id
  formulaChartBId  String?    // DashboardChart id
}

model PlanSeriesValue {
  id       String     @id @default(cuid())
  seriesId String
  series   PlanSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  month    String     // "2026-01"
  value    Float

  @@unique([seriesId, month])
}

model ChartSeriesLink {
  id       String         @id @default(cuid())
  chartId  String
  chart    DashboardChart @relation(fields: [chartId], references: [id], onDelete: Cascade)
  seriesId String
  series   PlanSeries     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  order    Int            @default(0)
  yAxis    String         @default("left")

  @@unique([chartId, seriesId])
}

model ExchangeRate {
  id        String @id @default(cuid())
  currency  String
  month     String // "2026-01"
  rateToUsd Float

  @@unique([currency, month])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Document {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  filename      String
  path          String
  mimetype      String?
  size          Int?
  uploadedAt    DateTime    @default(now())

  @@index([transactionId])
}

// ===== Multi-usuário =====
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String?
  role         String       @default("member") // "admin" | "member"
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  sessions             Session[]
  memberships          Membership[]
  operationMemberships OperationMembership[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Acesso de um usuário a um HOLDING (empresas e contas herdam do holding)
model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdingId String
  holding   Holding  @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, holdingId])
  @@index([userId])
  @@index([holdingId])
}

// ===== Credenciais por empresa (Mercury/Wise/Revolut/Meta) =====
model Credential {
  id          String     @id @default(cuid())
  issuer      String // "mercury" | "wise" | "revolut" | "meta"
  company     String
  token       String
  secrets     String? // JSON
  isActive    Boolean    @default(true)
  // Meta: conectada POR OPERAÇÃO (o operador conecta o próprio perfil). Bancos: null.
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([issuer, company])
  @@unique([issuer, operationId])
  @@index([issuer])
  @@index([operationId])
}

// ===== Recibos do Meta (PDF) — elo metaRef(extrato) ↔ transactionId(Meta) ↔ conta =====
model MetaReceipt {
  id              String    @id @default(cuid())
  transactionId   String    @unique // id numérico composto (= MetaBillingCharge.transactionId)
  referenceNumber String? // código alfanumérico do recibo (= Transaction.metaRef, case-insensitive)
  accountId       String? // conta de anúncio cobrada
  accountName     String?
  cardLast4       String?
  amountUsd       Float?
  date            DateTime?
  createdAt       DateTime  @default(now())

  @@index([referenceNumber])
  @@index([accountId])
}

// ===== Universo Meta controlado (contas + cartão de funding) =====
model MetaAdAccount {
  id               String   @id @default(cuid())
  accountId        String   @unique // id numérico Meta
  name             String
  currency         String?
  accountStatus    Int?
  company          String? // rótulo da credencial Meta dona (nome da operação)
  operationId      String? // operação dona desta conta Meta (FK de verdade)
  operation        Operation? @relation(fields: [operationId], references: [id], onDelete: SetNull)
  bmId             String?
  bmName           String?
  fundingCardBrand String?
  fundingCardLast4 String?
  fundingRaw       String?
  amountSpent      Float? // gasto total (lifetime) reportado pelo Meta, em unidades menores da moeda
  updatedAt        DateTime @updatedAt

  @@index([fundingCardLast4])
  @@index([operationId])
}

// Cobrança real de uma conta de anúncio (act_<id>/activities event=ad_account_billing_charge).
// É a "Atividade de pagamento" do Business Suite — valor + data + conta/BM, por API.
model MetaBillingCharge {
  id            String   @id @default(cuid())
  transactionId String   @unique // transaction_id do Meta (dedup)
  accountId     String // act id numérico
  accountName   String?
  bmId          String?
  bmName        String?
  operationId   String?
  amountUsd     Float // new_value/100 (na moeda do extra_data)
  currency      String
  chargedAt     DateTime
  createdAt     DateTime @default(now())

  @@index([accountId])
  @@index([chargedAt])
  @@index([amountUsd])
  @@index([operationId])
}

// Whitelist manual de cartões legítimos (double-check do que a API não expõe)
model CardWhitelist {
  id        String   @id @default(cuid())
  last4     String
  label     String?
  company   String?
  addedBy   String?
  createdAt DateTime @default(now())

  @@unique([last4, company])
  @@index([last4])
}
